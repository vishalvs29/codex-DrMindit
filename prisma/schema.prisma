generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
}

enum RiskLevel {
  LOW
  MODERATE
  ELEVATED
  CRISIS
}

model User {
  id              String          @id @default(cuid())
  clerkId         String          @unique
  email           String          @unique
  name            String?
  imageUrl        String?
  anonymousMode   Boolean         @default(false)
  preferredTone   String          @default("calm")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  organizationId  String?
  organization    Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  chatSessions    ChatSession[]
  moodEntries     MoodEntry[]
  audioSessions   AudioSession[]
  audioProgress   UserAudioProgress[]
  favoriteTracks  FavoriteTrack[]
  programProgress UserProgramProgress[]
  insights        Insight[]

  @@index([organizationId])
  @@index([email])
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  type        String
  seatCount   Int      @default(0)
  privacyMode Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  @@index([type])
}

model ChatSession {
  id          String    @id @default(cuid())
  userId      String
  title       String
  summary     String?
  riskLevel   RiskLevel @default(LOW)
  lastMood    String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@index([userId, updatedAt])
  @@index([userId, archivedAt])
}

model Message {
  id            String      @id @default(cuid())
  chatSessionId String
  role          Role
  content       String
  metadata      Json?
  tokenCount    Int?
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
  @@index([role])
}

model MoodEntry {
  id        String   @id @default(cuid())
  userId    String
  mood      String
  score     Int
  sleep     Int?
  stress    Int?
  journal   String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([mood])
}

model Program {
  id          String                @id @default(cuid())
  slug        String                @unique
  title       String
  description String
  duration    Int
  category    String
  accent      String                @default("from-cyanGlow to-mint")
  benefits    String[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  days        ProgramDay[]
  progress    UserProgramProgress[]

  @@index([category])
}

model ProgramDay {
  id          String        @id @default(cuid())
  programId   String
  dayNumber   Int
  title       String
  description String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  program     Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  tasks       ProgramTask[]

  @@unique([programId, dayNumber])
  @@index([programId, dayNumber])
}

model ProgramTask {
  id              String   @id @default(cuid())
  programDayId    String
  title           String
  description     String
  durationMinutes Int      @default(5)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  programDay      ProgramDay @relation(fields: [programDayId], references: [id], onDelete: Cascade)

  @@unique([programDayId, sortOrder])
  @@index([programDayId, sortOrder])
}

model UserProgramProgress {
  id                   String    @id @default(cuid())
  userId               String
  programId            String
  startedAt            DateTime  @default(now())
  completedAt          DateTime?
  completionPercentage Int       @default(0)
  completedTaskIds     String[]
  currentDay           Int       @default(1)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  program              Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([userId, completedAt])
  @@index([programId])
}

model AudioCategory {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tracks      AudioTrack[]
}

model AudioTrack {
  id          String              @id @default(cuid())
  categoryId  String
  slug        String              @unique
  title       String
  description String
  duration    Int
  audioUrl    String
  imageGradient String
  isPublished Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  category    AudioCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  progress    UserAudioProgress[]
  favorites   FavoriteTrack[]
  sessions    AudioSession[]

  @@index([categoryId])
  @@index([isPublished])
}

model AudioSession {
  id               String      @id @default(cuid())
  userId           String
  audioTrackId     String?
  title            String
  category         String
  duration         Int
  listenedSeconds  Int         @default(0)
  completed        Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioTrack       AudioTrack? @relation(fields: [audioTrackId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([audioTrackId])
  @@index([category])
}

model UserAudioProgress {
  id               String     @id @default(cuid())
  userId           String
  audioTrackId     String
  positionSeconds  Int        @default(0)
  listeningSeconds Int        @default(0)
  completed        Boolean    @default(false)
  lastPlayedAt     DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioTrack       AudioTrack @relation(fields: [audioTrackId], references: [id], onDelete: Cascade)

  @@unique([userId, audioTrackId])
  @@index([userId, lastPlayedAt])
  @@index([audioTrackId])
}

model FavoriteTrack {
  id           String     @id @default(cuid())
  userId       String
  audioTrackId String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioTrack   AudioTrack @relation(fields: [audioTrackId], references: [id], onDelete: Cascade)

  @@unique([userId, audioTrackId])
  @@index([userId, createdAt])
}

model Insight {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  score     Int?
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([source])
}
