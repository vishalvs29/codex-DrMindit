generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
}

enum RiskLevel {
  LOW
  MODERATE
  ELEVATED
  CRISIS
}

model User {
  id              String          @id @default(cuid())
  clerkId         String          @unique
  email           String          @unique
  name            String?
  imageUrl        String?
  anonymousMode   Boolean         @default(false)
  preferredTone   String          @default("calm")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  organizationId  String?
  organization    Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  chatSessions    ChatSession[]
  moodEntries     MoodEntry[]
  audioSessions   AudioSession[]
  programProgress ProgramProgress[]
  insights        Insight[]

  @@index([organizationId])
  @@index([email])
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  type        String
  seatCount   Int      @default(0)
  privacyMode Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  @@index([type])
}

model ChatSession {
  id          String    @id @default(cuid())
  userId      String
  title       String
  summary     String?
  riskLevel   RiskLevel @default(LOW)
  lastMood    String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@index([userId, updatedAt])
  @@index([userId, archivedAt])
}

model Message {
  id            String      @id @default(cuid())
  chatSessionId String
  role          Role
  content       String
  metadata      Json?
  tokenCount    Int?
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
  @@index([role])
}

model MoodEntry {
  id        String   @id @default(cuid())
  userId    String
  mood      String
  score     Int
  sleep     Int?
  stress    Int?
  journal   String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([mood])
}

model Program {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  description String
  duration    Int
  category    String
  lessons     Json
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  progress    ProgramProgress[]

  @@index([category])
}

model ProgramProgress {
  id        String   @id @default(cuid())
  userId    String
  programId String
  day       Int      @default(1)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([userId, completed])
}

model AudioSession {
  id        String   @id @default(cuid())
  userId    String
  title     String
  category  String
  duration  Int
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([category])
}

model Insight {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  score     Int?
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([source])
}
